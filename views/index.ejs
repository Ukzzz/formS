

<div class="card">
    <h1 class="section-title">Application Form</h1>
    <p class="section-subtitle">Join our team of stellar professionals. Fill out the details below.</p>

    <% if (success) { %>
        <div class="notification notification-success">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <%= success %>
        </div>
    <% } %>

    <% if (error) { %>
        <div class="notification notification-error">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            <%= error %>
        </div>
    <% } %>

    <form action="/submit" method="POST" enctype="multipart/form-data" id="applicationForm" autocomplete="off">
        <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="e.g. John Doe" required>
        </div>

        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="e.g. john@example.com" required>
        </div>

        <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="e.g. +1 234 567 8900" required>
        </div>

        <div class="form-group">
            <label for="degree">Highest Degree</label>
            <input type="text" id="degree" name="degree" placeholder="e.g. Bachelor of Computer Science" required>
        </div>

        <div class="form-group">
            <label for="resume">Upload Resume (PDF/Word)</label>
            <div class="file-upload-wrapper" id="dropArea">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 0.5rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                <p style="font-size: 0.875rem; color: var(--text-muted);">Click to upload or drag and drop</p>
                <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" required style="position: absolute; inset: 0; opacity: 0; cursor: pointer;">
                <p id="fileName" class="mt-4" style="font-size: 0.75rem; color: var(--primary); font-weight: 500;"></p>
            </div>
        </div>

        <button type="submit" class="btn btn-primary" id="submitBtn">
            <span>Submit Application</span>
        </button>
    </form>
</div>

<script>
    const fileInput = document.getElementById('resume');
    const fileName = document.getElementById('fileName');
    const dropArea = document.getElementById('dropArea');

    fileInput.addEventListener('change', (e) => {
        if (e.target.files.length > 0) {
            fileName.textContent = `Selected: ${e.target.files[0].name}`;
            dropArea.style.borderColor = 'var(--primary)';
        }
    });

    // Basic drag and drop visual feedback
    ['dragenter', 'dragover'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropArea.style.borderColor = 'var(--primary)';
            dropArea.style.backgroundColor = 'rgba(79, 70, 229, 0.05)';
        }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropArea.addEventListener(eventName, (e) => {
            e.preventDefault();
            if (!fileInput.files.length) {
                dropArea.style.borderColor = 'var(--border)';
                dropArea.style.backgroundColor = 'transparent';
            }
        }, false);
    });
</script>
